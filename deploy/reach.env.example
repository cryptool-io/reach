# Production env for Reach on ronserver2 — copy to /data/www/main/reach/.env (chmod 600).
# Loaded into the process by PM2 via node --env-file (see ecosystem.config.cjs).

NODE_ENV=production
HOST=127.0.0.1
PORT=3400

# adapter-node uses ORIGIN so SvelteKit knows it's behind nginx/HTTPS:
# fixes secure-cookie setting, redirects, and form-action CSRF (Origin check).
ORIGIN=https://reach.cryptool.io

# Base URL baked into open/click tracking links (must be the public HTTPS origin).
PUBLIC_BASE_URL=https://reach.cryptool.io

# PostgreSQL (local cluster on this server). Password generated at deploy time.
DATABASE_URL=postgresql://reach_user:REPLACE_ME@localhost:5432/reach_db?schema=public

# Encrypts mailbox/channel credentials at rest. Generate: openssl rand -hex 32
APP_SESSION_SECRET=REPLACE_ME

# AI provider — set ANY ONE to switch the agents on (free-tier first). Auto-picks the first present
# (Gemini → Groq → Cerebras → OpenRouter → Mistral → Grok → Anthropic) and falls back if one rate-limits.
GEMINI_API_KEY=        # https://aistudio.google.com/apikey   (free)
GROQ_API_KEY=          # https://console.groq.com/keys        (free, fast)
CEREBRAS_API_KEY=      # https://cloud.cerebras.ai            (free, fastest)
OPENROUTER_API_KEY=    # https://openrouter.ai/keys           (free models)
MISTRAL_API_KEY=       # https://console.mistral.ai/api-keys  (free tier)
XAI_API_KEY=           # Grok (paid/credits)
ANTHROPIC_API_KEY=     # Claude (paid)
# LLM_PRIORITY=groq,gemini

# Data enrichment for Lead Finder — apollo.io → Settings → Integrations → API
APOLLO_API_KEY=
