# Database (SQLite for dev; path is relative to prisma/. Swap to postgres://... for prod)
DATABASE_URL="file:./dev.db"

# AI provider — set ANY ONE (free-tier first). The app auto-picks the first present
# (priority: Gemini → Groq → Cerebras → OpenRouter → Mistral → Grok → Anthropic) and falls back
# if one rate-limits. Reorder with LLM_PRIORITY; override a model with <PROVIDER>_MODEL.
GEMINI_API_KEY=""        # https://aistudio.google.com/apikey  (free)
GROQ_API_KEY=""          # https://console.groq.com/keys       (free, fast)
CEREBRAS_API_KEY=""      # https://cloud.cerebras.ai           (free, fastest)
OPENROUTER_API_KEY=""    # https://openrouter.ai/keys          (free models available)
MISTRAL_API_KEY=""       # https://console.mistral.ai/api-keys (free tier)
XAI_API_KEY=""           # https://console.x.ai  (Grok — paid/credits)
ANTHROPIC_API_KEY=""     # https://console.anthropic.com (paid)
# LLM_PRIORITY="groq,gemini"
# GEMINI_MODEL="gemini-2.5-flash"

# Data enrichment — licensed verified contacts for Lead Finder. Get a key at
# apollo.io → Settings → Integrations → API. (Compliant alternative to scraping.)
APOLLO_API_KEY=""

# Single-user auth (v0 stub)
APP_USER_EMAIL="info@cryptool.io"
APP_SESSION_SECRET="change-me"

# Gmail OAuth (post-v0 wiring)
GMAIL_CLIENT_ID=""
GMAIL_CLIENT_SECRET=""

# X / Twitter (post-v0)
X_BEARER_TOKEN=""

# Telegram bot (post-v0)
TELEGRAM_BOT_TOKEN=""

# Discord bot (post-v0)
DISCORD_BOT_TOKEN=""
